generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  name          String?
  passwordHash  String
  role          String  @default("MEMBER") // ADMIN, BOARD, MEMBER
  position      String? // Presidente, Tesorero, etc.
  isBoardMember Boolean @default(false)
  member        Member?

  // Track registrations recorded by this user
  recordedRegistrations EventRegistration[] @relation("RecordedBy")
  recordedFees          MembershipFee[]     @relation("FeeRecordedBy")
  buffetSalesRecorded   BuffetSale[]        @relation("BuffetRecordedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id           String    @id @default(uuid())
  memberNumber String
  firstName    String
  lastName     String
  dni          String    @unique
  address      String?
  city         String?
  email        String?
  phone        String?
  joinDate     DateTime  @default(now())
  birthDate    DateTime?
  type         String    @default("ACTIVO") // ACTIVO, HONORARIO
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE, DEBTOR, SUSPENDED, DECEASED, RESIGNED

  // Board status
  isBoardMember Boolean @default(false)
  position      String? // e.g. "Vocal", "Presidente"

  // New: Family Discount (50%)
  isFamilyDiscount Boolean  @default(false)
  partnerId        String?
  partner          Member?  @relation("MemberPartner", fields: [partnerId], references: [id])
  partnerOf        Member[] @relation("MemberPartner")

  wantsMailing Boolean @default(true)
  notes        String?
  userId       String? @unique
  user         User?   @relation(fields: [userId], references: [id])

  fees                MembershipFee[]
  communications      Communication[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  avatarUrl           String? // For digital ID
  deactivatedAt       DateTime?
  eventRegistrations  EventRegistration[]
  championshipResults ChampionshipResult[] @relation("MemberAwards")
  boardHistory        BoardHistory[]
  buffetPurchases     BuffetSale[]         @relation("BuffetBuyer")
}

model Communication {
  id       String   @id @default(uuid())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id])
  type     String // WELCOME, DEBT_REMINDER, EVENT_INFO, GENERAL
  subject  String
  content  String
  sentBy   String?
  sentAt   DateTime @default(now())
  status   String   @default("SENT") // SENT, FAILED, PENDING
  channel  String   @default("EMAIL") // EMAIL, WHATSAPP, MANUAL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MembershipFee {
  id            String   @id @default(uuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  periodYear    Int
  periodMonth   Int
  amountDue     Float
  amountPaid    Float
  paymentDate   DateTime
  paymentMethod String?
  paymentStatus String // PAID, PARTIAL
  notes         String?

  // Track recording user for fees too
  recordedById String?
  recordedBy   User?   @relation("FeeRecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, periodYear, periodMonth])
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String
  status      String    @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Teacher {
  id     String  @id @default(uuid())
  name   String
  bio    String?
  events Event[] @relation("EventTeachers")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?   @default("Sede Central CAT")
  type        String // MILONGA, WORKSHOP, BOTH

  // Specific Schedules and Locations
  milongaStart    DateTime?
  milongaEnd      DateTime?
  milongaLocation String?
  tangoDJ         String?

  workshopStart    DateTime?
  workshopEnd      DateTime?
  workshopLocation String?
  workshopClasses  String? // JSON String with [{name, start, end, description}]

  organizer String @default("Centro Amigos del Tango")

  // Pricing
  priceSocioMilonga        Float?
  priceNonSocioMilonga     Float?
  priceSocioWorkshop       Float?
  priceNonSocioWorkshop    Float?
  priceSocioFull           Float?
  priceNonSocioFull        Float?
  priceSocioSingleClass    Float?
  priceNonSocioSingleClass Float?

  status      String  @default("OPEN") // OPEN, CLOSED, ARCHIVED
  isPublic    Boolean @default(true) // For website visibility
  eventBanner String? // URL/Path to designed banner image

  teachers      Teacher[]           @relation("EventTeachers")
  registrations EventRegistration[]
  buffetSales   BuffetSale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventRegistration {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // Link to member if exists, otherwise manual data
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  firstName String
  lastName  String
  dni       String?
  email     String?
  phone     String?

  registrationType String // MILONGA, WORKSHOP, FULL
  amountPaid       Float   @default(0)
  paymentStatus    String  @default("PENDING") // PENDING, PAID
  paymentMethod    String? // CASH, TRANSFER, etc
  paymentProof     String? // URL/Path to image

  // Source tracking
  source       String  @default("MANAGEMENT") // WEB, MANAGEMENT
  recordedById String?
  recordedBy   User?   @relation("RecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Championship {
  id          String               @id @default(uuid())
  year        Int
  name        String               @default("Vientos de Tango")
  description String? // Optional description of this championship edition
  results     ChampionshipResult[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([year, name])
}

model ChampionshipResult {
  id             String       @id @default(uuid())
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id])

  category String // TANGO PISTA, MILONGA, VALS, TANGO ESCENARIO
  place    Int // 1, 2, 3

  // Link to member if they are a current member
  memberId String?
  member   Member? @relation("MemberAwards", fields: [memberId], references: [id])

  // Names of the couple (since one or both might not be members)
  firstName   String
  lastName    String
  partnerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoardHistory {
  id          String   @id @default(uuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  position    String // e.g. "Presidente", "Vocal"
  periodStart String? // e.g. "2012"
  periodEnd   String? // e.g. "2023"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BuffetProduct {
  id        String   @id @default(uuid())
  name      String
  brand     String?
  size      String?
  price     Float
  type      String // BEBIDAS_SIN_ALCOHOL, BEBIDAS_CON_ALCOHOL, COMIDA
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems BuffetSaleItem[]
}

model BuffetSale {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  amountTotal   Float
  amountPaid    Float
  paymentMethod String // CASH, TRANSFER, MERCADOPAGO, A_COBRAR

  buyerName String?
  buyerId   String?
  buyer     Member? @relation("BuffetBuyer", fields: [buyerId], references: [id])

  recordedById String?
  recordedBy   User?   @relation("BuffetRecordedBy", fields: [recordedById], references: [id])

  items BuffetSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BuffetSaleItem {
  id          String        @id @default(uuid())
  saleId      String
  sale        BuffetSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     BuffetProduct @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtSale Float

  @@unique([saleId, productId])
}

model EscuelitaStudent {
  id          String                @id @default(uuid())
  dni         String                @unique
  firstName   String
  lastName    String
  email       String?
  phone       String?
  attendances EscuelitaAttendance[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model EscuelitaClass {
  id          String                @id @default(uuid())
  date        DateTime              @default(now())
  teachers    String // Nombres de los profesores
  photoUrl    String?
  attendances EscuelitaAttendance[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model EscuelitaAttendance {
  id        String           @id @default(uuid())
  studentId String
  classId   String
  student   EscuelitaStudent @relation(fields: [studentId], references: [id])
  escuelita EscuelitaClass   @relation(fields: [classId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([studentId, classId])
}

// ============================================
// JUEGOS — Acertijo 2.0
// ============================================

model TriviaQuestion {
  id            String   @id @default(uuid())
  statement     String   // Enunciado de la pregunta
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String   // "A", "B", "C", "D"
  category      String   // historia, orquestas, cantantes, etc.
  difficulty    String   @default("MEDIUM") // EASY, MEDIUM, HARD
  isActive      Boolean  @default(true)
  answers       TriviaAnswer[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TriviaGame {
  id               String         @id @default(uuid())
  name             String         @default("Acertijo 2.0")
  isActive         Boolean        @default(false)
  
  // -- Campos para Juego en Vivo --
  status           String         @default("IDLE") // IDLE, WAITING_QUESTION, TIMER_ACTIVE, SHOWING_RESULTS
  currentQuestionId String?       
  currentQuestionIndex Int          @default(0)
  timerDuration    Int            @default(10)     // Segundos ajustables
  timerEndAt       DateTime?                        // Para sincronizar el reloj
  activeQuestionIds String[]      @default([])     // Las 10 preguntas elegidas para la sesión
  // -------------------------------

  questionsPerGame Int            @default(10)
  timePerQuestion  Int            @default(30) // Segundos (Default para modo offline)
  totalTimeLimit   Int?           // Segundos, null = sin límite
  pointsCorrect    Int            @default(10)
  pointsIncorrect  Int            @default(0) // Penalización
  sessions         TriviaSession[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TriviaPlayer {
  id        String          @id @default(uuid())
  firstName String
  lastName  String
  nickname  String?
  email     String?
  phone     String?
  sessions  TriviaSession[]
  createdAt DateTime        @default(now())
}

model TriviaSession {
  id             String        @id @default(uuid())
  playerId       String
  player         TriviaPlayer  @relation(fields: [playerId], references: [id])
  gameId         String
  game           TriviaGame    @relation(fields: [gameId], references: [id])
  totalCorrect   Int           @default(0)
  totalIncorrect Int           @default(0)
  totalTime      Int           @default(0) // Milisegundos
  score          Int           @default(0)
  completedAt    DateTime?
  answers        TriviaAnswer[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model TriviaAnswer {
  id             String         @id @default(uuid())
  sessionId      String
  session        TriviaSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId     String
  question       TriviaQuestion @relation(fields: [questionId], references: [id])
  selectedOption String         // "A", "B", "C", "D"
  isCorrect      Boolean
  timeTaken      Int            // Milisegundos
  createdAt      DateTime       @default(now())

  @@unique([sessionId, questionId])
}
